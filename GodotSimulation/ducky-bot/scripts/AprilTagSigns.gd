extends Node3D

# AprilTag (36h11) sign textures embedded as raw L8 pixel bytes (base64).
# 64x64 grayscale: 48px marker + 8px quiet zone.  No PNG format, no import
# pipeline needed — Godot builds the Image directly from raw pixel data.
# Tag IDs match project_config.yaml:  9=t_right  10=t_left  11=t_junction

const _W := 64
const _H := 64

const _RAW: Dictionary = {
	"Tag9_Approach1": "",
	"Tag10_Approach2": "",
	"Tag11_Approach3": "",
}

func _ready() -> void:
	for node_name in _RAW:
		var mesh_node = get_node_or_null(node_name)
		if mesh_node == null:
			push_warning("AprilTagSigns: child not found: " + node_name)
			continue

		var raw: PackedByteArray = Marshalls.base64_to_raw(_RAW[node_name])
		if raw.size() != _W * _H:
			push_warning("AprilTagSigns: unexpected byte count %d for %s" % [raw.size(), node_name])
			continue

		var img := Image.create_from_data(_W, _H, false, Image.FORMAT_L8, raw)
		var tex := ImageTexture.create_from_image(img)

		var mat := StandardMaterial3D.new()
		mat.albedo_texture = tex
		mat.shading_mode = BaseMaterial3D.SHADING_MODE_UNSHADED
		mat.cull_mode = BaseMaterial3D.CULL_DISABLED
		mesh_node.material_override = mat
