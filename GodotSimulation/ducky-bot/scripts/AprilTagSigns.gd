extends Node3D

# AprilTag (36h11) sign textures, indexed by integer tag ID.
#
# HOW TO ADD MORE SIGNS IN THE EDITOR:
#   1. Add a MeshInstance3D child (or duplicate an existing one).
#   2. Name it  Tag9_<anything>   Tag10_<anything>   or   Tag11_<anything>
#   3. Run the scene — texture and label appear automatically.
#
# Tag meanings (matches project_config.yaml):
#   Tag9  = t_right   -> agent picks STRAIGHT or RIGHT
#   Tag10 = t_left    -> agent picks STRAIGHT or LEFT
#   Tag11 = t_junction -> agent picks LEFT or RIGHT  (no straight)

const _W := 64
const _H := 64

const _LABELS := {
	9:  "T9: STR/RIGHT",
	10: "T10: STR/LEFT",
	11: "T11: L/R only",
}

const _RAW_BY_ID: Dictionary = {
	9: "",
	10: "",
	11: "",
}

# Cache textures so duplicates share the same ImageTexture object
var _tex_cache: Dictionary = {}


func _ready() -> void:
	for child in get_children():
		if not child is MeshInstance3D:
			continue
		var tag_id := _parse_tag_id(child.name)
		if tag_id < 0:
			push_warning("AprilTagSigns: '%s' — name must start with Tag9_, Tag10_, or Tag11_" % child.name)
			continue
		if not _RAW_BY_ID.has(tag_id):
			push_warning("AprilTagSigns: no texture data for tag id %d (node '%s')" % [tag_id, child.name])
			continue
		_apply_texture(child as MeshInstance3D, tag_id)
		_add_label(child as MeshInstance3D, tag_id)


func _parse_tag_id(node_name: String) -> int:
	if not node_name.begins_with("Tag"):
		return -1
	var rest := node_name.substr(3)
	var sep  := rest.find("_")
	var id_str := rest.substr(0, sep) if sep >= 0 else rest
	if id_str.is_valid_int():
		return id_str.to_int()
	return -1


func _apply_texture(mesh_node: MeshInstance3D, tag_id: int) -> void:
	if not _tex_cache.has(tag_id):
		var raw: PackedByteArray = Marshalls.base64_to_raw(_RAW_BY_ID[tag_id])
		if raw.size() != _W * _H:
			push_warning("AprilTagSigns: bad byte count for tag %d" % tag_id)
			return
		var img := Image.create_from_data(_W, _H, false, Image.FORMAT_L8, raw)
		_tex_cache[tag_id] = ImageTexture.create_from_image(img)

	var mat := StandardMaterial3D.new()
	mat.albedo_texture = _tex_cache[tag_id]
	mat.shading_mode   = BaseMaterial3D.SHADING_MODE_UNSHADED
	mat.cull_mode      = BaseMaterial3D.CULL_DISABLED
	mesh_node.material_override = mat


func _add_label(mesh_node: MeshInstance3D, tag_id: int) -> void:
	var lbl        := Label3D.new()
	lbl.text       = _LABELS.get(tag_id, "Tag%d" % tag_id)
	lbl.font_size  = 32
	lbl.pixel_size = 0.0003          # ≈ 1 cm tall in world space
	lbl.position   = Vector3(0, 0.07, 0)   # just above the sign quad
	lbl.billboard  = BaseMaterial3D.BILLBOARD_ENABLED
	lbl.no_depth_test = true         # always visible, even through walls
	mesh_node.add_child(lbl)
